{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Gateway (Local)",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/gateway",
      "env": {
        "DATABASE_HOST": "localhost",
        "DATABASE_PORT": "5432",
        "DATABASE_NAME": "goconnect",
        "DATABASE_USER": "postgres",
        "DATABASE_PASSWORD": "postgres",
        "REDIS_HOST": "localhost",
        "REDIS_PORT": "6379",
        "JWT_SECRET": "your-secret-key-min-32-chars-long",
        "JWT_ACCESS_EXPIRY": "15m",
        "JWT_REFRESH_EXPIRY": "7d",
        "ENV": "development",
        "LOG_LEVEL": "debug",
        "GATEWAY_PORT": "8080",
        "AUTH_SERVICE_HOST": "localhost",
        "AUTH_SERVICE_PORT": "50051"
      }
    },
    {
      "name": "Debug Auth Service (Local)",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/auth-service",
      "env": {
        "DATABASE_HOST": "localhost",
        "DATABASE_PORT": "5432",
        "DATABASE_NAME": "goconnect",
        "DATABASE_USER": "postgres",
        "DATABASE_PASSWORD": "postgres",
        "REDIS_HOST": "localhost",
        "REDIS_PORT": "6379",
        "JWT_SECRET": "your-secret-key-min-32-chars-long",
        "JWT_ACCESS_EXPIRY": "15m",
        "JWT_REFRESH_EXPIRY": "7d",
        "ENV": "development",
        "LOG_LEVEL": "debug",
        "AUTH_SERVICE_PORT": "50051"
      }
    },
    {
      "name": "Debug Gateway (Remote K8s)",
      "type": "go",
      "request": "attach",
      "mode": "remote",
      "remotePath": "/root",
      "port": 30040,
      "host": "localhost",
      "showLog": true,
      "trace": "verbose",
      "substitutePath": [
        {
          "from": "${workspaceFolder}",
          "to": "/root"
        }
      ]
    },
    {
      "name": "Debug Auth Service (Remote K8s)",
      "type": "go",
      "request": "attach",
      "mode": "remote",
      "remotePath": "/root",
      "port": 30041,
      "host": "localhost",
      "showLog": true,
      "trace": "verbose",
      "substitutePath": [
        {
          "from": "${workspaceFolder}",
          "to": "/root"
        }
      ]
    },
    {
      "name": "Test Current File",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${file}"
    },
    {
      "name": "Test Current Package",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}"
    }
  ]
}
