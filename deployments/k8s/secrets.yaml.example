apiVersion: v1
kind: Secret
metadata:
  name: goconnect-secrets
  namespace: goconnect
type: Opaque
stringData:
  database-host: "postgres-service"
  database-port: "5432"
  database-name: "goconnect"
  database-user: "postgres"
  database-password: "CHANGE_ME"
  redis-host: "redis-service"
  redis-port: "6379"
  redis-password: ""
  jwt-secret: "CHANGE_ME_generate_strong_random_key"
  otp-secret: "CHANGE_ME_generate_strong_random_key"
  totp-encryption-key: "CHANGE_ME_use_generate_encryption_key_script"
  google-client-id: "your_google_client_id"
  google-client-secret: "your_google_client_secret"
  facebook-client-id: "your_facebook_client_id"
  facebook-client-secret: "your_facebook_client_secret"
  github-client-id: "your_github_client_id"
  github-client-secret: "your_github_client_secret"
  smtp-host: "smtp.gmail.com"
  smtp-port: "587"
  smtp-username: "your_email@example.com"
  smtp-password: "your_app_password"
  from-email: "your_email@example.com"
  from-name: "GoConnect"
