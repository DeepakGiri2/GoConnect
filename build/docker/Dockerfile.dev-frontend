# ⚠️ DEVELOPMENT ONLY - DO NOT USE IN PRODUCTION ⚠️
FROM golang:1.23-alpine

WORKDIR /app

# Copy go module files first
COPY go.mod go.sum ./

# Download dependencies
RUN go mod download

# Copy dev server code
COPY cmd/dev-server/ ./cmd/dev-server/
COPY temp/ ./temp/

# Expose dev server port
EXPOSE 3000

# Set environment variable
ENV DEV_SERVER_PORT=3000

# Run dev server
CMD ["go", "run", "cmd/dev-server/main.go"]
